{
  "openapi": "3.1.0",
  "info": {
    "title": "Transmute API",
    "description": "API to interact with Transmute without the need for a frontend",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://YOUR_TRANSMUTE_IP:3313",
      "description": "Transmute API server"
    }
  ],
  "paths": {
    "/api/health/info": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Get application metadata",
        "description": "Return application metadata",
        "operationId": "app_info_api_health_info_get",
        "responses": {
          "200": {
            "description": "Application metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/health/live": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Liveness check",
        "description": "Simple liveness check to confirm the server is running",
        "operationId": "liveness_api_health_live_get",
        "responses": {
          "200": {
            "description": "Liveness status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/health/ready": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Readiness check",
        "description": "Readiness check to confirm the server is ready to handle requests",
        "operationId": "readiness_api_health_ready_get",
        "responses": {
          "200": {
            "description": "Ready - all checks passed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          },
          "503": {
            "description": "Not ready - one or more checks failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/files": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "List all uploaded files",
        "description": "List all uploaded files",
        "operationId": "list_files_api_files_get",
        "responses": {
          "200": {
            "description": "List of all uploaded files",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "files"
        ],
        "summary": "Upload a file",
        "description": "Upload a file and save it to the server",
        "operationId": "upload_file_api_files_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_file_api_files_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileUploadResponse"
                }
              }
            }
          },
          "500": {
            "description": "Upload failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/{file_id}": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "Download a converted file",
        "description": "Download a file",
        "operationId": "get_file_api_files__file_id__get",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content as binary",
            "content": {
              "application/octet-stream": {}
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "files"
        ],
        "summary": "Delete an uploaded file",
        "description": "Delete an uploaded file",
        "operationId": "delete_file_api_files__file_id__delete",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileDeleteResponse"
                }
              }
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/batch": {
      "post": {
        "tags": [
          "files"
        ],
        "summary": "Batch download converted files",
        "description": "Batch download converted files as a ZIP archive",
        "operationId": "batch_download_files_api_files_batch_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchDownloadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "ZIP file containing all converted files",
            "content": {
              "application/zip": {}
            }
          },
          "404": {
            "description": "One or more converted files not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/all": {
      "delete": {
        "tags": [
          "files"
        ],
        "summary": "Delete all uploaded files",
        "description": "Delete all uploaded files",
        "operationId": "delete_all_files_api_files_all_delete",
        "responses": {
          "200": {
            "description": "All files deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileDeleteResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversions/complete": {
      "get": {
        "tags": [
          "conversions"
        ],
        "summary": "List completed conversions",
        "description": "List all completed conversions with their converted and original file metadata.",
        "operationId": "list_conversions_api_conversions_complete_get",
        "responses": {
          "200": {
            "description": "List of completed conversions with original and converted file metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversions": {
      "post": {
        "tags": [
          "conversions"
        ],
        "summary": "Create a new conversion",
        "description": "Create a new conversion for a previously uploaded file.",
        "operationId": "create_conversion_api_conversions_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful conversion - returns metadata of the converted file",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileMetadata"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or conversion error (no converter found)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "File not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversions/all": {
      "delete": {
        "tags": [
          "conversions"
        ],
        "summary": "Delete all converted files and their relations to the original files",
        "description": "Delete all converted files and their relations to the original files",
        "operationId": "delete_all_conversions_api_conversions_all_delete",
        "responses": {
          "200": {
            "description": "Conversion history deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileDeleteResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversions/{conversion_id}": {
      "delete": {
        "tags": [
          "conversions"
        ],
        "summary": "Delete a converted file and its relation to the original file",
        "description": "Delete a converted file and its relation to the original file",
        "operationId": "delete_conversion_api_conversions__conversion_id__delete",
        "parameters": [
          {
            "name": "conversion_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Conversion Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversion history deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileDeleteResponse"
                }
              }
            }
          },
          "404": {
            "description": "Conversion history not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/converters": {
      "get": {
        "tags": [
          "converters"
        ],
        "summary": "List all available converters",
        "operationId": "list_converters_api_converters_get",
        "responses": {
          "200": {
            "description": "List of converters with supported input and output formats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConverterMetadataListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "List Jobs",
        "operationId": "list_jobs_api_jobs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "tags": [
          "settings"
        ],
        "summary": "Get app settings",
        "description": "Return the current application settings.",
        "operationId": "get_app_settings_api_settings_get",
        "responses": {
          "200": {
            "description": "Current app settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppSettingsResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "settings"
        ],
        "summary": "Update app settings",
        "description": "Partially update application settings. Only provided fields are changed.",
        "operationId": "update_app_settings_api_settings_patch",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppSettingsUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated app settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppSettingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid settings value"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppInfo": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Application name",
            "example": "Transmute"
          },
          "version": {
            "type": "string",
            "title": "Version",
            "description": "Application version",
            "example": "v1.0.0"
          }
        },
        "type": "object",
        "required": [
          "name",
          "version"
        ],
        "title": "AppInfo"
      },
      "AppSettingsResponse": {
        "properties": {
          "theme": {
            "type": "string",
            "enum": [
              "rubedo",
              "citrinitas",
              "viriditas",
              "nigredo",
              "albedo",
              "aurora",
              "caelum"
            ],
            "title": "Theme",
            "description": "Active UI theme",
            "example": "rubedo"
          },
          "auto_download": {
            "type": "boolean",
            "title": "Auto Download",
            "description": "Auto-download converted files on completion",
            "example": false
          },
          "keep_originals": {
            "type": "boolean",
            "title": "Keep Originals",
            "description": "Retain uploaded source files after conversion",
            "example": true
          },
          "cleanup_ttl_minutes": {
            "type": "integer",
            "title": "Cleanup Ttl Minutes",
            "description": "Time-to-live in minutes for cleanup",
            "example": 60
          }
        },
        "type": "object",
        "required": [
          "theme",
          "auto_download",
          "keep_originals",
          "cleanup_ttl_minutes"
        ],
        "title": "AppSettingsResponse"
      },
      "AppSettingsUpdate": {
        "properties": {
          "theme": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "rubedo",
                  "citrinitas",
                  "viriditas",
                  "nigredo",
                  "albedo",
                  "aurora",
                  "caelum"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Theme",
            "description": "UI theme to apply",
            "example": "rubedo"
          },
          "auto_download": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Auto Download",
            "description": "Auto-download on completion",
            "example": false
          },
          "keep_originals": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Keep Originals",
            "description": "Keep original files after conversion",
            "example": true
          },
          "cleanup_ttl_minutes": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cleanup Ttl Minutes",
            "description": "Time-to-live in minutes for cleanup",
            "example": 60
          }
        },
        "type": "object",
        "title": "AppSettingsUpdate"
      },
      "BatchDownloadRequest": {
        "properties": {
          "file_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "File Ids",
            "description": "List of converted file IDs to download",
            "example": [
              "123e4567-e89b-12d3-a456-426614174000",
              "987fcdeb-51a2-43f1-b789-123456789abc"
            ]
          }
        },
        "type": "object",
        "required": [
          "file_ids"
        ],
        "title": "BatchDownloadRequest"
      },
      "Body_upload_file_api_files_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_file_api_files_post"
      },
      "ConversionItem": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "original_filename": {
            "type": "string",
            "title": "Original Filename",
            "example": "example.jpg"
          },
          "media_type": {
            "type": "string",
            "title": "Media Type",
            "example": "png"
          },
          "extension": {
            "type": "string",
            "title": "Extension",
            "example": ".png"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes",
            "example": 204800
          },
          "sha256_checksum": {
            "type": "string",
            "title": "Sha256 Checksum",
            "example": "abc123def456..."
          },
          "original_file": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/FileMetadata"
              },
              {
                "type": "null"
              }
            ],
            "description": "Original file metadata"
          }
        },
        "type": "object",
        "required": [
          "id",
          "original_filename",
          "media_type",
          "extension",
          "size_bytes",
          "sha256_checksum"
        ],
        "title": "ConversionItem"
      },
      "ConversionListResponse": {
        "properties": {
          "conversions": {
            "items": {
              "$ref": "#/components/schemas/ConversionItem"
            },
            "type": "array",
            "title": "Conversions",
            "description": "List of completed conversions"
          }
        },
        "type": "object",
        "required": [
          "conversions"
        ],
        "title": "ConversionListResponse"
      },
      "ConversionRequest": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "ID of file to convert",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "output_format": {
            "type": "string",
            "title": "Output Format",
            "description": "Target format for conversion",
            "example": "png"
          }
        },
        "type": "object",
        "required": [
          "id",
          "output_format"
        ],
        "title": "ConversionRequest"
      },
      "ConverterMetadata": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "example": "drawio_convert"
          },
          "supported_input_formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Supported Input Formats",
            "example": [
              "drawio"
            ]
          },
          "supported_output_formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Supported Output Formats",
            "example": [
              "png",
              "pdf",
              "jpg"
            ]
          }
        },
        "type": "object",
        "required": [
          "name",
          "supported_input_formats",
          "supported_output_formats"
        ],
        "title": "ConverterMetadata"
      },
      "ConverterMetadataListResponse": {
        "properties": {
          "converters": {
            "items": {
              "$ref": "#/components/schemas/ConverterMetadata"
            },
            "type": "array",
            "title": "Converters",
            "description": "List of the available converters"
          }
        },
        "type": "object",
        "required": [
          "converters"
        ],
        "title": "ConverterMetadataListResponse"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail",
            "description": "Error message",
            "example": "No converter found for jpg to png"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse"
      },
      "FileDeleteResponse": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Deletion status message",
            "example": "File deleted successfully"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "FileDeleteResponse"
      },
      "FileListResponse": {
        "properties": {
          "files": {
            "items": {
              "$ref": "#/components/schemas/FileMetadata"
            },
            "type": "array",
            "title": "Files",
            "description": "List of uploaded files"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "FileListResponse"
      },
      "FileMetadata": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "original_filename": {
            "type": "string",
            "title": "Original Filename",
            "example": "example.jpg"
          },
          "media_type": {
            "type": "string",
            "title": "Media Type",
            "example": "jpg"
          },
          "extension": {
            "type": "string",
            "title": "Extension",
            "example": ".jpg"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes",
            "example": 204800
          },
          "sha256_checksum": {
            "type": "string",
            "title": "Sha256 Checksum",
            "example": "abc123def456..."
          }
        },
        "type": "object",
        "required": [
          "id",
          "original_filename",
          "media_type",
          "extension",
          "size_bytes",
          "sha256_checksum"
        ],
        "title": "FileMetadata"
      },
      "FileMetadataWithFormats": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "original_filename": {
            "type": "string",
            "title": "Original Filename",
            "example": "example.jpg"
          },
          "media_type": {
            "type": "string",
            "title": "Media Type",
            "example": "jpg"
          },
          "extension": {
            "type": "string",
            "title": "Extension",
            "example": ".jpg"
          },
          "size_bytes": {
